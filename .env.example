# Copiar este archivo como .env y completar los valores
# NUNCA subir el archivo .env a GitHub

# Token de Hugging Face (obtener en: huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cuenta de Gmail desde la que se envía el reporte
GMAIL_USER=tu_email@gmail.com

# Contraseña de aplicación de Gmail (NO es tu contraseña normal)
# Cómo obtenerla: myaccount.google.com > Seguridad > Verificación en 2 pasos > Contraseñas de aplicación
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email donde querés recibir el reporte (puede ser el mismo que GMAIL_USER)
EMAIL_DESTINATARIO=tu_email@gmail.com
